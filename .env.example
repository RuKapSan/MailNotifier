# === Telegram ===
# Создай бота через @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Узнай свой ID через @userinfobot
TELEGRAM_CHAT_ID=your_chat_id_here

# === Mail.ru Calendar (выбери ОДИН из двух способов) ===

# --- Способ 1: CalDAV (рекомендуется) ---
# Нужен email и пароль приложения (НЕ основной пароль!)
# Как получить пароль приложения:
#   1. Зайди на mail.ru → Настройки → Безопасность
#   2. Раздел "Пароли для внешних приложений"
#   3. Создай новый пароль, назови "Calendar Notifier"
#   4. Скопируй сгенерированный пароль сюда
CALDAV_URL=https://calendar.mail.ru/.well-known/caldav
CALDAV_USERNAME=your_email@mail.ru
CALDAV_PASSWORD=your_app_password_here

# --- Способ 2: ICS ссылка (проще, но без авто-принятия) ---
# Как получить:
#   1. Зайди на calendar.mail.ru
#   2. Нажми ⚙ рядом с нужным календарём
#   3. Найди "Экспорт" или "iCal" ссылку
#   4. Скопируй URL сюда
ICS_URL=

# === Настройки уведомлений ===
# За сколько минут до события напоминать (через запятую)
# 1440 = 1 день, 60 = 1 час
REMIND_BEFORE_MINUTES=1440,60
# Как часто проверять календарь (секунды)
POLL_INTERVAL_SECONDS=60
# Часовой пояс
TIMEZONE=Europe/Moscow
